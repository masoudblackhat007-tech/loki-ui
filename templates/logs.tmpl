{{ define "logs" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Loki UI - Requests</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    :root {
      --ts-bg: #020617;
      --ts-border: #111827;
      --ts-border-subtle: #1f2937;
      --ts-text: #e5e7eb;
      --ts-text-subtle: #9ca3af;
      --ts-primary: #22c55e;
      --ts-primary-soft: rgba(34,197,94,0.15);
      --ts-danger: #ef4444;
      --ts-danger-soft: rgba(239,68,68,0.15);
      --ts-warn: #f97316;
      --ts-warn-soft: rgba(249,115,22,0.15);
      --ts-blue-soft: rgba(59,130,246,0.15);
      --ts-blue: #60a5fa;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      max-width: 100%;
      overflow-x: hidden;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 15% -10%, rgba(34,197,94,0.08), transparent 55%),
        radial-gradient(circle at 90% -10%, rgba(59,130,246,0.05), transparent 55%),
        var(--ts-bg);
      color: var(--ts-text);
    }

    .telescope-layout {
      display: flex;
      width: 100%;
      max-width: 100%;
      min-height: 100vh;
    }

    .ts-sidebar {
      width: 230px;
      background: #020617;
      border-right: 1px solid var(--ts-border);
      padding: 16px 12px;
      position: sticky;
      top: 0;
      align-self: flex-start;
      height: 100vh;
    }

    .ts-sidebar-header {
      display: flex;
      align-items: center;
      margin-bottom: 24px;
    }

    .ts-logo {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #22c55e, #16a34a, #22c55e);
      box-shadow: 0 0 0 2px rgba(34,197,94,0.3), 0 10px 25px rgba(0,0,0,0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #020617;
      margin-right: 10px;
      font-size: 16px;
    }

    .ts-app-name {
      font-weight: 600;
      font-size: 14px;
    }

    .ts-app-env {
      font-size: 11px;
      color: var(--ts-text-subtle);
    }

    .ts-nav-section {
      font-size: 11px;
      text-transform: uppercase;
      color: var(--ts-text-subtle);
      margin: 8px 8px 6px;
      letter-spacing: .04em;
    }

    .ts-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .ts-nav-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 11px;
      border-radius: 8px;
      border: none;
      background: transparent;
      color: var(--ts-text);
      text-decoration: none;
      font-size: 14px;
      cursor: pointer;
    }

    .ts-nav-item--active {
      background: radial-gradient(circle at 0 0, rgba(34,197,94,0.35), transparent 60%);
      box-shadow: inset 0 0 0 1px rgba(15,23,42,0.8);
    }

    .ts-nav-item:not(.ts-nav-item--disabled):hover {
      background: rgba(15,23,42,0.9);
    }

    .ts-nav-item--disabled {
      opacity: .35;
      cursor: default;
    }

    .ts-nav-icon {
      width: 20px;
      text-align: center;
    }

    .ts-main {
      flex: 1;
      width: 100%;
      min-width: 0;
      max-width: calc(100% - 230px);
      padding: 16px 24px 20px;
    }

    .ts-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }

    .ts-header-title {
      margin: 0;
      font-size: 22px;
      font-weight: 600;
    }

    .ts-header-subtitle {
      font-size: 12px;
      color: var(--ts-text-subtle);
    }

    .ts-header-right {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 8px;
    }

    .ts-header-buttons {
      display: flex;
      gap: 8px;
    }

    .ts-icon-btn {
      background: rgba(15,23,42,0.9);
      border: 1px solid var(--ts-border);
      border-radius: 999px;
      color: var(--ts-text);
      width: 32px;
      height: 32px;
      cursor: pointer;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .ts-icon-btn:hover {
      border-color: var(--ts-primary);
      background: #020617;
    }

    .ts-filters {
      background: rgba(15,23,42,0.95);
      border-radius: 12px;
      border: 1px solid var(--ts-border);
      padding: 10px 12px;
      margin-bottom: 8px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.45);
    }

    .ts-filters-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgba(31,41,55,0.75);
    }

    .ts-filters-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--ts-text);
    }

    .ts-filters-help {
      font-size: 11px;
      color: var(--ts-text-subtle);
      line-height: 1.5;
      max-width: 720px;
    }

    .ts-filters-form label {
      display: flex;
      flex: 1 1 180px;
      flex-direction: column;
      font-size: 11px;
      color: var(--ts-text-subtle);
      gap: 2px;
    }

    .ts-filters-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 6px;
    }

    .ts-filters-row input,
    .ts-filters-row select,
    .ts-project-local-filters input {
      background: #020617;
      border-radius: 7px;
      border: 1px solid var(--ts-border-subtle);
      padding: 4px 7px;
      font-size: 12px;
      color: var(--ts-text);
      width: 100%;
      min-width: 0;
    }

    .ts-filters-row input:focus,
    .ts-filters-row select:focus,
    .ts-project-local-filters input:focus {
      outline: none;
      border-color: var(--ts-primary);
      box-shadow: 0 0 0 1px rgba(34,197,94,0.35);
      background: #020617;
    }

    .ts-filters-actions {
      display: flex;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 8px;
      margin-left: auto;
    }

    .ts-btn {
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 12px;
      cursor: pointer;
      border: 1px solid transparent;
      background: #111827;
      color: var(--ts-text);
      white-space: nowrap;
      text-decoration: none;
      display: inline-block;
    }

    .ts-btn-outline {
      border-color: #4b5563;
      background: transparent;
    }

    .ts-btn-ghost {
      background: transparent;
      border-color: transparent;
      color: var(--ts-text-subtle);
    }

    .ts-btn-xs {
      padding: 2px 8px;
      font-size: 11px;
      border-radius: 999px;
      border: 1px solid #4b5563;
      background: transparent;
      color: var(--ts-text);
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      text-align: center;
    }

    .ts-btn:hover,
    .ts-btn-xs:hover {
      background: #020617;
      border-color: var(--ts-primary);
    }

    .ts-summary-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 12px;
      color: var(--ts-text-subtle);
      margin-bottom: 8px;
    }

    .ts-summary-right {
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
    }

    .ts-summary-pill {
      font-size: 11px;
      padding: 2px 10px;
      border-radius: 999px;
      background: #020617;
      border: 1px solid var(--ts-border);
      color: var(--ts-text-subtle);
    }

    .ts-projects-log-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .ts-project-card {
      border: 1px solid var(--ts-border);
      border-radius: 14px;
      background: rgba(15,23,42,0.97);
      box-shadow: 0 18px 40px rgba(0,0,0,0.55);
      overflow: hidden;
    }

    .ts-project-header {
      width: 100%;
      border: 0;
      border-bottom: 1px solid var(--ts-border);
      background: #020617;
      color: var(--ts-text);
      padding: 12px 14px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      text-align: left;
    }

    .ts-project-title {
      display: flex;
      flex-direction: column;
      gap: 3px;
      min-width: 0;
    }

    .ts-project-title-line {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .ts-project-chevron {
      color: var(--ts-text-subtle);
      transition: transform .12s ease;
    }

    .ts-project-card.is-open .ts-project-chevron {
      transform: rotate(90deg);
    }

    .ts-project-name {
      font-size: 14px;
      font-weight: 700;
      word-break: break-word;
    }

    .ts-project-meta {
      font-size: 11px;
      color: var(--ts-text-subtle);
    }

    .ts-project-stats {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 6px;
      font-size: 11px;
      color: var(--ts-text-subtle);
    }

    .ts-project-body {
      padding: 12px;
      display: none;
    }

    .ts-project-card.is-open .ts-project-body {
      display: block;
    }

    .ts-project-local-filters {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) 120px 120px;
      gap: 8px;
      margin-bottom: 10px;
    }

    .ts-project-local-filters input {
      border-radius: 999px;
      border: 1px solid var(--ts-border);
      padding: 7px 10px;
    }

    .ts-empty-state {
      border: 1px solid var(--ts-border);
      border-radius: 12px;
      padding: 18px;
      color: var(--ts-text-subtle);
      background: rgba(15,23,42,0.97);
    }

    .ts-table-wrapper {
      border-radius: 12px;
      border: 1px solid var(--ts-border);
      background: rgba(15,23,42,0.97);
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      box-shadow: 0 18px 40px rgba(0,0,0,0.7);
    }

    .ts-table {
      width: 100%;
      min-width: 980px;
      border-collapse: collapse;
      font-size: 13px;
    }

    .ts-table thead {
      background: #020617;
      position: sticky;
      top: 0;
      z-index: 2;
    }

    .ts-table th {
      text-align: left;
      padding: 8px 12px;
      border-bottom: 1px solid var(--ts-border);
      color: var(--ts-text-subtle);
      font-weight: 500;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .04em;
      background: #020617;
    }

    .ts-row td {
      padding: 7px 12px;
      border-bottom: 1px solid rgba(15,23,42,0.95);
      font-size: 13px;
      vertical-align: top;
    }

    .ts-row:nth-child(odd) {
      background: rgba(15,23,42,0.96);
    }

    .ts-row:nth-child(even) {
      background: rgba(15,23,42,0.99);
    }

    .ts-row:hover {
      background: #020617;
    }

    .ts-cell-error {
      max-width: 420px;
    }

    .ts-error-text {
      margin: 0;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 12px;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .ts-badge-method {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      color: var(--ts-text);
      border-radius: 999px;
      padding: 2px 10px;
      background: radial-gradient(circle at 0 0, rgba(148,163,184,0.75), rgba(15,23,42,1));
      display: inline-block;
    }

    .ts-badge-service {
      font-size: 11px;
      font-weight: 600;
      border-radius: 999px;
      padding: 2px 10px;
      background: var(--ts-blue-soft);
      color: var(--ts-blue);
      border: 1px solid rgba(59,130,246,0.4);
      display: inline-block;
      white-space: nowrap;
      max-width: 220px;
      overflow: hidden;
      text-overflow: ellipsis;
      vertical-align: middle;
    }

    .ts-badge-status {
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
      border: 1px solid rgba(31,41,55,0.9);
      background: rgba(15,23,42,0.9);
      min-width: 42px;
      text-align: center;
    }

    .ts-status-2xx {
      background: var(--ts-primary-soft);
      color: var(--ts-primary);
      border-color: rgba(34,197,94,0.6);
    }

    .ts-status-4xx {
      background: var(--ts-warn-soft);
      color: var(--ts-warn);
      border-color: rgba(249,115,22,0.6);
    }

    .ts-status-5xx {
      background: var(--ts-danger-soft);
      color: var(--ts-danger);
      border-color: rgba(239,68,68,0.6);
    }

    .ts-time-abs {
      font-weight: 600;
    }

    .ts-time-ago {
      font-size: 11px;
      color: var(--ts-text-subtle);
      margin-top: 2px;
    }

    .ts-filter-copy {
      border: 0;
      background: transparent;
      color: inherit;
      padding: 0;
      margin: 0;
      font: inherit;
      cursor: pointer;
      text-align: left;
      max-width: 100%;
    }

    .ts-filter-copy:hover {
      color: var(--ts-primary);
      text-decoration: underline;
    }

    .ts-filter-copy.ts-badge-method {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      color: var(--ts-text);
      border-radius: 999px;
      padding: 2px 10px;
      background: radial-gradient(circle at 0 0, rgba(148,163,184,0.75), rgba(15,23,42,1));
      display: inline-block;
    }

    .ts-filter-copy.ts-badge-service {
      font-size: 11px;
      font-weight: 600;
      border-radius: 999px;
      padding: 2px 10px;
      background: var(--ts-blue-soft);
      color: var(--ts-blue);
      border: 1px solid rgba(59,130,246,0.4);
      display: inline-block;
      white-space: nowrap;
      max-width: 220px;
      overflow: hidden;
      text-overflow: ellipsis;
      vertical-align: middle;
    }

    .ts-filter-copy.ts-badge-status {
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
      min-width: 42px;
      text-align: center;
    }

    .ts-input-clear-wrap {
      position: relative;
      display: block;
      width: 100%;
    }

    .ts-input-clear-wrap input {
      padding-right: 28px !important;
    }

    .ts-input-clear-btn {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      border: 0;
      border-radius: 999px;
      background: rgba(148,163,184,0.18);
      color: var(--ts-text-subtle);
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      line-height: 18px;
      padding: 0;
    }

    .ts-input-clear-wrap.has-value .ts-input-clear-btn {
      display: inline-flex;
    }

    .ts-input-clear-btn:hover {
      background: rgba(239,68,68,0.22);
      color: var(--ts-danger);
    }

    @media (max-width: 1100px) {
      .ts-sidebar {
        display: none;
      }

      .ts-main {
        max-width: 100%;
        padding: 14px 16px 18px;
      }
    }

    @media (max-width: 760px) {
      .telescope-layout {
        display: block;
      }

      .ts-main {
        padding: 12px;
      }

      .ts-header {
        align-items: flex-start;
        flex-direction: column;
      }

      .ts-header-left,
      .ts-header-right {
        width: 100%;
      }

      .ts-header-buttons {
        width: 100%;
      }

      .ts-header-buttons .ts-icon-btn {
        flex: 1 1 0;
        width: auto;
      }

      .ts-filters {
        padding: 10px;
      }

      .ts-filters-header {
        flex-direction: column;
      }

      .ts-filters-row {
        gap: 8px;
      }

      .ts-filters-form label,
      .ts-filters-row label[style] {
        flex: 1 1 100% !important;
      }

      .ts-filters-actions {
        width: 100%;
        margin-left: 0;
      }

      .ts-filters-actions .ts-btn {
        flex: 1 1 100%;
        min-height: 34px;
      }

      .ts-summary-bar {
        align-items: flex-start;
        flex-direction: column;
      }

      .ts-project-header {
        align-items: flex-start;
        flex-direction: column;
      }

      .ts-project-stats {
        justify-content: flex-start;
      }

      .ts-project-local-filters {
        grid-template-columns: 1fr;
      }

      .ts-table-wrapper {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
        overflow-y: visible;
        border-radius: 12px;
        background: transparent;
        border: none;
        box-shadow: none;
      }

      .ts-table,
      .ts-table thead,
      .ts-table tbody,
      .ts-table th,
      .ts-table td,
      .ts-table tr {
        display: block;
      }

      .ts-table {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
        font-size: 13px;
      }

      .ts-table thead {
        display: none;
      }

      .ts-row {
        width: 100%;
        max-width: 100%;
        border: 1px solid var(--ts-border);
        border-radius: 12px;
        background: rgba(15,23,42,0.97) !important;
        margin-top: 10px;
        overflow: hidden;
      }

      .ts-row td {
        display: grid;
        grid-template-columns: minmax(72px, 30%) minmax(0, 1fr);
        width: 100%;
        max-width: 100%;
        min-width: 0;
        gap: 10px;
        align-items: start;
        padding: 8px 10px;
        border-bottom: 1px solid rgba(31,41,55,0.75);
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .ts-row td > * {
        min-width: 0;
        max-width: 100%;
        overflow-wrap: anywhere;
      }

      .ts-row td::before {
        content: attr(data-label);
        color: var(--ts-text-subtle);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
      }

      .ts-row td:last-child {
        border-bottom: none;
      }

      .ts-badge-method,
      .ts-badge-service,
      .ts-badge-status,
      .ts-btn-xs {
        justify-self: start;
      }

      .ts-badge-service {
        max-width: 100%;
        white-space: normal;
      }

      .ts-cell-error {
        max-width: none;
      }

      .ts-error-text {
        max-width: 100%;
        overflow-wrap: anywhere;
      }
    }
  </style>
</head>

<body>
<div class="telescope-layout">

  <aside class="ts-sidebar">
    <div class="ts-sidebar-header">
      <div class="ts-logo">L</div>
      <div class="ts-title">
        <div class="ts-app-name">Loki Telescope</div>
        <div class="ts-app-env">Laravel Logs</div>
      </div>
    </div>

    <nav class="ts-nav">
      <div class="ts-nav-section">Monitor</div>

      <a href="/logs" class="ts-nav-item ts-nav-item--active">
        <span class="ts-nav-icon">📡</span>
        <span>Requests</span>
      </a>

      <button class="ts-nav-item ts-nav-item--disabled" type="button">
        <span class="ts-nav-icon">💾</span>
        <span>DB Queries</span>
      </button>

      <button class="ts-nav-item ts-nav-item--disabled" type="button">
        <span class="ts-nav-icon">⚠️</span>
        <span>Exceptions</span>
      </button>

      <button class="ts-nav-item ts-nav-item--disabled" type="button">
        <span class="ts-nav-icon">📝</span>
        <span>Logs</span>
      </button>
    </nav>
  </aside>

  <main class="ts-main">

    <header class="ts-header">
      <div class="ts-header-left">
        <h1 class="ts-header-title">Requests</h1>
        <span class="ts-header-subtitle">Real-time HTTP requests from Laravel (via Loki)</span>
      </div>

      <div class="ts-header-right">
        <div class="ts-header-buttons">
          <button type="button" id="pauseResumeBtn" class="ts-icon-btn" title="Pause / Resume">⏸</button>
          <button type="button" id="refreshOnceBtn" class="ts-icon-btn" title="Refresh now">🔄</button>
        </div>
      </div>
    </header>

    <section class="ts-filters">
      <div class="ts-filters-header">
        <div>
          <div class="ts-filters-title">Server-side Loki filters</div>
          <div class="ts-filters-help">
            These filters change the query sent to Loki. Project filters inside each card only filter the already fetched rows.
          </div>
        </div>
      </div>

      <form id="logsFilterForm" class="ts-filters-form" action="/logs" method="get">
        <div class="ts-filters-row">
          <label>
            Project label
            <input type="text" name="service" value="{{ .Service }}" placeholder="service_name, e.g. laravel-log3-loki">
          </label>

          <label>
            Lookback range
            <select name="range" id="rangeSelect">
              <option value="15m" {{ if eq .Range "15m" }}selected{{ end }}>Last 15 minutes</option>
              <option value="1h"  {{ if eq .Range "1h"  }}selected{{ end }}>Last 1 hour</option>
              <option value="6h"  {{ if eq .Range "6h"  }}selected{{ end }}>Last 6 hours</option>
              <option value="24h" {{ if eq .Range "24h" }}selected{{ end }}>Last 24 hours</option>
            </select>
          </label>

          <label>
            Max rows fetched
            <input type="number" name="limit" value="{{ .Limit }}" min="1" max="2000" placeholder="maximum rows returned by Loki">
          </label>
        </div>

        <div class="ts-filters-row">
          <label style="flex:2">
            Request ID
            <input type="text" name="request_id" value="{{ .RequestID }}" placeholder="exact correlation id">
          </label>

          <label style="flex:2">
            Loki text contains
            <input type="text" name="text" value="{{ .Text }}" placeholder="server-side raw log text filter">
          </label>

          <div class="ts-filters-actions">
            <button type="submit" class="ts-btn ts-btn-outline">Apply server filters</button>
            <button type="button" id="clearFiltersBtn" class="ts-btn ts-btn-ghost">Clear filters</button>
          </div>
        </div>
      </form>
    </section>

    <section class="ts-summary-bar">
      <div class="ts-summary-left">
        Total fetched HTTP entries: <span id="totalEntries">{{ .Total }}</span>
      </div>
      <div class="ts-summary-right">
        <span id="summaryHttp" class="ts-summary-pill"></span>
        <span id="summaryInfo" class="ts-summary-pill"></span>
      </div>
    </section>

    <section id="projects-log-list" class="ts-projects-log-list">
      <div class="ts-empty-state">Loading logs...</div>
    </section>

  </main>
</div>

<script>
  let autoRefresh = true;
  let refreshTimer = null;
  let projectRenderTimer = null;
  let lastFetchedCount = 0;
  let lastFilteredLogs = [];
  let projectFilterState = {};
  const UI_TIMEZONE = 'Asia/Tehran';
  const PROJECT_RENDER_DELAY_MS = 180;

  function escapeHtml(str) {
    if (str === null || str === undefined) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function escapeAttr(str) {
    return escapeHtml(str).replace(/'/g, '&#39;');
  }

  function updateClearButton(input) {
    const wrap = input.closest('.ts-input-clear-wrap');
    if (!wrap) return;

    if (input.value) wrap.classList.add('has-value');
    else wrap.classList.remove('has-value');
  }

  function enhanceClearableInputs(root) {
    const scope = root || document;

    scope.querySelectorAll('input').forEach(function (input) {
      if (input.type === 'hidden') return;

      if (input.closest('.ts-input-clear-wrap')) {
        updateClearButton(input);
        return;
      }

      const wrap = document.createElement('span');
      wrap.className = 'ts-input-clear-wrap';

      input.parentNode.insertBefore(wrap, input);
      wrap.appendChild(input);

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ts-input-clear-btn';
      btn.setAttribute('aria-label', 'Clear input');
      btn.textContent = '×';

      btn.addEventListener('click', function () {
        input.value = '';
        updateClearButton(input);

        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.dispatchEvent(new Event('change', { bubbles: true }));
        input.focus();
      });

      input.addEventListener('input', function () {
        updateClearButton(input);
      });

      input.addEventListener('change', function () {
        updateClearButton(input);
      });

      wrap.appendChild(btn);
      updateClearButton(input);
    });
  }

  function getFocusedProjectInput() {
    const input = document.activeElement;

    if (!input || !input.matches || !input.matches('[data-project-filter]')) {
      return null;
    }

    const card = input.closest('.ts-project-card');
    if (!card) return null;

    return {
      key: card.getAttribute('data-project-key') || '',
      name: input.getAttribute('data-project-filter') || '',
      start: input.selectionStart,
      end: input.selectionEnd
    };
  }

  function restoreProjectInputFocus(focusState) {
    if (!focusState || !focusState.key || !focusState.name) return;

    let card = null;

    document.querySelectorAll('.ts-project-card').forEach(function (item) {
      if (item.getAttribute('data-project-key') === focusState.key) {
        card = item;
      }
    });

    if (!card) return;

    const input = card.querySelector('[data-project-filter="' + focusState.name + '"]');
    if (!input) return;

    input.focus();

    try {
      if (typeof focusState.start === 'number' && typeof focusState.end === 'number') {
        input.setSelectionRange(focusState.start, focusState.end);
      }
    } catch (e) {}
  }

  function scheduleProjectRender(skipDomSync) {
    const focusState = getFocusedProjectInput();

    if (projectRenderTimer !== null) {
      clearTimeout(projectRenderTimer);
    }

    projectRenderTimer = setTimeout(function () {
      projectRenderTimer = null;
      renderProjects(lastFilteredLogs, !!skipDomSync, focusState);
    }, PROJECT_RENDER_DELAY_MS);
  }

  function projectKey(project) {
    return encodeURIComponent(String(project || 'unknown-project'));
  }

  function formatAgo(tsNano) {
    if (!tsNano || tsNano <= 0) return '';
    const ms = tsNano / 1e6;
    const diffMs = Date.now() - ms;
    const sec = Math.floor(diffMs / 1000);

    if (sec < 0) return '0s ago';
    if (sec < 60) return sec + 's ago';

    const min = Math.floor(sec / 60);
    if (min < 60) return min + 'm ago';

    const h = Math.floor(min / 60);
    if (h < 24) return h + 'h ago';

    const d = Math.floor(h / 24);
    return d + 'd ago';
  }

  function formatDateTimeTZ(tsNano) {
    if (!tsNano || tsNano <= 0) return '';
    const d = new Date(tsNano / 1e6);

    return d.toLocaleString('sv-SE', {
      timeZone: UI_TIMEZONE,
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).replace('T', ' ');
  }

  function getContext(log) {
    return log && log.context ? log.context : {};
  }

  function getLabels(log) {
    return log && log.labels ? log.labels : {};
  }

  function getServiceFromLog(log) {
    const ctx = getContext(log);
    const labels = getLabels(log);

    const service =
      (log && log.service) ||
      ctx.service ||
      ctx.project ||
      labels.service_name ||
      labels.service ||
      labels.project ||
      '';

    return service ? String(service) : 'unknown-project';
  }

  function getStatusFromLog(log) {
    const ctx = getContext(log);
    return log && log.status != null ? log.status : ctx.status_code;
  }

  function getMethodFromLog(log) {
    const ctx = getContext(log);
    return String((log && log.method) || ctx.method || '').toUpperCase();
  }

  function getPathFromLog(log) {
    const ctx = getContext(log);
    return (log && log.route) || ctx.route || ctx.path || '';
  }

  function getDurationFromLog(log) {
    const ctx = getContext(log);
    return log && log.duration_ms != null ? log.duration_ms : ctx.duration_ms;
  }

  function getRequestIdFromLog(log) {
    const ctx = getContext(log);
    return (log && log.request_id) || ctx.request_id || '';
  }

  function getErrorTextFromLog(log) {
    const ctx = getContext(log);

    return (
      (log && log.safe_message) ||
      ctx.safe_message ||
      (log && log.error_code) ||
      ctx.error_code ||
      (log && log.response_message) ||
      ctx.response_message ||
      (log && log.response_error_code) ||
      ctx.response_error_code ||
      ''
    );
  }

  function buildSearchText(log) {
    const ctx = getContext(log);
    const labels = getLabels(log);
    const ts = log && (log.ts || log.timestamp) ? (log.ts || log.timestamp) : 0;

    return (
      ((log && log.message) || '') + ' ' +
      getPathFromLog(log) + ' ' +
      getServiceFromLog(log) + ' ' +
      getMethodFromLog(log) + ' ' +
      String(getStatusFromLog(log) || '') + ' ' +
      formatDateTimeTZ(ts) + ' ' +
      (labels.service_name || '') + ' ' +
      (labels.service || '') + ' ' +
      (labels.project || '') + ' ' +
      getErrorTextFromLog(log) + ' ' +
      JSON.stringify(ctx)
    ).toLowerCase();
  }

  function applyClientFilters(logs) {
    return logs.filter(function (log) {
      return log && log.log_type === 'http_request';
    });
  }

  function applyProjectFilters(logs, state) {
    const searchText = (state.search || '').trim().toLowerCase();
    const methodFilter = (state.method || '').trim().toUpperCase();
    const statusFilter = (state.status || '').trim();

    return logs.filter(function (log) {
      const method = getMethodFromLog(log);
      const statusNum = getStatusFromLog(log);
      const status = statusNum != null ? String(statusNum) : '';

      if (methodFilter && method !== methodFilter) return false;
      if (statusFilter && status !== statusFilter) return false;
      if (searchText && buildSearchText(log).indexOf(searchText) === -1) return false;

      return true;
    });
  }

  function countStatuses(logs) {
    const counts = { total: logs.length, s2xx: 0, s4xx: 0, s5xx: 0 };

    logs.forEach(function (log) {
      const statusNum = Number(getStatusFromLog(log));
      if (Number.isNaN(statusNum)) return;

      if (statusNum >= 200 && statusNum < 300) counts.s2xx++;
      else if (statusNum >= 400 && statusNum < 500) counts.s4xx++;
      else if (statusNum >= 500) counts.s5xx++;
    });

    return counts;
  }

  function groupLogsByProject(logs) {
    const groups = new Map();

    logs.forEach(function (log) {
      const project = getServiceFromLog(log);
      if (!groups.has(project)) groups.set(project, []);
      groups.get(project).push(log);
    });

    return Array.from(groups.entries()).sort(function (a, b) {
      return a[0].localeCompare(b[0]);
    });
  }

  function renderLogTable(logs, stateKey) {
    if (logs.length === 0) {
      return '<div class="ts-empty-state">No logs match this project filter.</div>';
    }

    let html = ''
      + '<section class="ts-table-wrapper">'
      + '<table class="ts-table">'
      + '<thead><tr>'
      + '<th style="width:90px;">Verb</th>'
      + '<th style="width:140px;">Service</th>'
      + '<th>Path</th>'
      + '<th style="width:90px;">Status</th>'
      + '<th style="width:90px;">Duration</th>'
      + '<th>Error</th>'
      + '<th style="width:190px;">Time</th>'
      + '<th style="width:110px;">Ago</th>'
      + '<th style="width:80px;">Details</th>'
      + '</tr></thead><tbody>';

    logs.forEach(function (log) {
      const method = getMethodFromLog(log);
      const path = getPathFromLog(log);
      const service = getServiceFromLog(log);
      const labels = getLabels(log);
      const serviceLabel = labels.service_name || service;
      const statusNum = getStatusFromLog(log);
      const status = statusNum != null ? String(statusNum) : '';
      const durationMs = getDurationFromLog(log);
      const duration = durationMs != null ? String(durationMs) + ' ms' : '';
      const ts = log.ts || log.timestamp || 0;
      const ago = formatAgo(ts);
      const absTime = formatDateTimeTZ(ts);
      const requestId = getRequestIdFromLog(log);
      const errorText = getErrorTextFromLog(log);

      let statusClass = 'ts-badge-status';
      const statusNumber = Number(statusNum);

      if (!Number.isNaN(statusNumber)) {
        if (statusNumber >= 200 && statusNumber < 300) statusClass += ' ts-status-2xx';
        else if (statusNumber >= 400 && statusNumber < 500) statusClass += ' ts-status-4xx';
        else if (statusNumber >= 500) statusClass += ' ts-status-5xx';
      }

      const detailsCell = requestId
        ? '<a href="/logs/detail?request_id=' + encodeURIComponent(requestId) + '" target="_blank" class="ts-btn-xs">JSON</a>'
        : '<span class="ts-btn-xs" style="opacity:.5;cursor:default;">JSON</span>';

      const errorCellHtml = errorText
        ? '<pre class="ts-error-text">' + escapeHtml(errorText) + '</pre>'
        : '—';

      html += ''
        + '<tr class="ts-row">'
        + '<td data-label="Verb"><button type="button" class="ts-filter-copy ts-badge-method" data-project-key="' + escapeAttr(stateKey) + '" data-filter-target="method" data-filter-value="' + escapeAttr(method) + '" title="Filter this project by method">' + escapeHtml(method || '—') + '</button></td>'
        + '<td data-label="Service"><button type="button" class="ts-filter-copy ts-badge-service" data-project-key="' + escapeAttr(stateKey) + '" data-filter-target="global-service" data-filter-value="' + escapeAttr(serviceLabel) + '" title="Filter all projects by service_name">' + escapeHtml(service || '—') + '</button></td>'
        + '<td data-label="Path"><button type="button" class="ts-filter-copy" data-project-key="' + escapeAttr(stateKey) + '" data-filter-target="search" data-filter-value="' + escapeAttr(path) + '" title="Search this project by path">' + escapeHtml(path || '—') + '</button></td>'
        + '<td data-label="Status"><button type="button" class="ts-filter-copy ' + statusClass + '" data-project-key="' + escapeAttr(stateKey) + '" data-filter-target="status" data-filter-value="' + escapeAttr(status) + '" title="Filter this project by status">' + escapeHtml(status || '—') + '</button></td>'
        + '<td data-label="Duration">' + escapeHtml(duration || '—') + '</td>'
        + '<td class="ts-cell-error" data-label="Error">' + errorCellHtml + '</td>'
        + '<td data-label="Time"><button type="button" class="ts-filter-copy ts-time-abs" data-project-key="' + escapeAttr(stateKey) + '" data-filter-target="search" data-filter-value="' + escapeAttr(absTime) + '" title="Search this project by time">' + escapeHtml(absTime || '—') + '</button></td>'
        + '<td data-label="Ago"><div class="ts-time-ago">' + escapeHtml(ago || '—') + '</div></td>'
        + '<td data-label="Details">' + detailsCell + '</td>'
        + '</tr>';
    });

    html += '</tbody></table></section>';

    return html;
  }

  function syncProjectStateFromDom() {
    document.querySelectorAll('.ts-project-card').forEach(function (card) {
      const key = card.getAttribute('data-project-key');
      if (!key) return;

      if (!projectFilterState[key]) {
        projectFilterState[key] = { open: false, search: '', method: '', status: '' };
      }

      projectFilterState[key].open = card.classList.contains('is-open');

      const search = card.querySelector('[data-project-filter="search"]');
      const method = card.querySelector('[data-project-filter="method"]');
      const status = card.querySelector('[data-project-filter="status"]');

      if (search) projectFilterState[key].search = search.value;
      if (method) projectFilterState[key].method = method.value;
      if (status) projectFilterState[key].status = status.value;
    });
  }

  function renderProjects(logs, skipDomSync, focusState) {
    const container = document.getElementById('projects-log-list');
    if (!container) return;

    if (!skipDomSync) {
      syncProjectStateFromDom();
    }

    const groups = groupLogsByProject(logs);

    if (groups.length === 0) {
      container.innerHTML = '<div class="ts-empty-state">No logs found.</div>';
      return;
    }

    let html = '';

    groups.forEach(function (entry, index) {
      const project = entry[0];
      const key = projectKey(project);
      const projectLogs = entry[1];

      if (!projectFilterState[key]) {
        projectFilterState[key] = {
          open: index === 0,
          search: '',
          method: '',
          status: ''
        };
      }

      const state = projectFilterState[key];
      const visibleLogs = applyProjectFilters(projectLogs, state);
      const allCounts = countStatuses(projectLogs);
      const visibleCounts = countStatuses(visibleLogs);
      const openClass = state.open ? ' is-open' : '';

      html += ''
        + '<section class="ts-project-card' + openClass + '" data-project-key="' + escapeHtml(key) + '">'
        + '<button type="button" class="ts-project-header" data-project-toggle="1">'
        + '<span class="ts-project-title">'
        + '<span class="ts-project-title-line">'
        + '<span class="ts-project-chevron">›</span>'
        + '<span class="ts-project-name">' + escapeHtml(project) + '</span>'
        + '</span>'
        + '<span class="ts-project-meta">Showing ' + visibleCounts.total + ' of ' + allCounts.total + ' logs</span>'
        + '</span>'
        + '<span class="ts-project-stats">'
        + '<span class="ts-summary-pill">2xx: ' + visibleCounts.s2xx + '</span>'
        + '<span class="ts-summary-pill">4xx: ' + visibleCounts.s4xx + '</span>'
        + '<span class="ts-summary-pill">5xx: ' + visibleCounts.s5xx + '</span>'
        + '</span>'
        + '</button>'
        + '<div class="ts-project-body">'
        + '<div class="ts-project-local-filters">'
        + '<input type="text" data-project-filter="search" value="' + escapeHtml(state.search) + '" placeholder="Search this project">'
        + '<input type="text" data-project-filter="method" value="' + escapeHtml(state.method) + '" placeholder="GET">'
        + '<input type="number" data-project-filter="status" value="' + escapeHtml(state.status) + '" placeholder="200">'
        + '</div>'
        + renderLogTable(visibleLogs, key)
        + '</div>'
        + '</section>';
    });

    container.innerHTML = html;
    enhanceClearableInputs(container);
    restoreProjectInputFocus(focusState);
  }

  async function fetchLogsAjax() {
    const form = document.getElementById('logsFilterForm');
    if (!form) return;

    const formData = new FormData(form);
    const params = new URLSearchParams();

    for (const [key, value] of formData.entries()) {
      if (!value) continue;
      params.set(key, value);
    }

    const url = '/api/logs?' + params.toString();
    let res;

    try {
      res = await fetch(url);
    } catch (e) {
      console.error('fetch /api/logs failed', e);
      return;
    }

    if (!res.ok) {
      console.error('fetch /api/logs status', res.status);
      return;
    }

    let data;

    try {
      data = await res.json();
    } catch (e) {
      console.error('invalid JSON from /api/logs', e);
      return;
    }

    const allLogs = data.logs || [];
    const logs = applyClientFilters(allLogs);
    lastFilteredLogs = logs;

    const totalSpan = document.getElementById('totalEntries');
    const summaryInfo = document.getElementById('summaryInfo');
    const summaryHttp = document.getElementById('summaryHttp');
    const counts = countStatuses(logs);

    if (totalSpan) totalSpan.textContent = String(logs.length);

    if (summaryHttp) {
      summaryHttp.textContent =
        '2xx: ' + counts.s2xx + '  •  4xx: ' + counts.s4xx + '  •  5xx: ' + counts.s5xx;
    }

    if (summaryInfo) {
      const changed = logs.length !== lastFetchedCount;
      lastFetchedCount = logs.length;
      summaryInfo.textContent = changed
        ? 'Updated ' + new Date().toLocaleTimeString()
        : 'No change';
    }

    renderProjects(logs, false, getFocusedProjectInput());
  }

  function startAutoRefresh() {
    if (refreshTimer !== null) clearInterval(refreshTimer);
    refreshTimer = setInterval(fetchLogsAjax, 3000);
  }

  function stopAutoRefresh() {
    if (refreshTimer !== null) {
      clearInterval(refreshTimer);
      refreshTimer = null;
    }
  }

  function toggleAutoRefresh() {
    autoRefresh = !autoRefresh;

    const btn = document.getElementById('pauseResumeBtn');
    if (btn) btn.textContent = autoRefresh ? '⏸' : '▶';

    if (autoRefresh) startAutoRefresh();
    else stopAutoRefresh();
  }

  function clearFilters() {
    const form = document.getElementById('logsFilterForm');
    if (!form) return;

    Array.prototype.forEach.call(form.elements, function (el) {
      if (el.tagName !== 'INPUT' && el.tagName !== 'SELECT') return;
      if (el.name === 'range' || el.name === 'limit') return;
      el.value = '';
    });

    projectFilterState = {};
    enhanceClearableInputs(document);
    fetchLogsAjax();
  }

  function applyCellFilter(button) {
    const key = button.getAttribute('data-project-key');
    const target = button.getAttribute('data-filter-target') || 'search';
    let value = button.getAttribute('data-filter-value') || '';

    if (!key || !value) return;

    if (!projectFilterState[key]) {
      projectFilterState[key] = { open: true, search: '', method: '', status: '' };
    }

    if (target === 'global-service') {
      const serviceInput = document.querySelector('input[name="service"]');
      if (!serviceInput) return;

      value = value.trim();

      serviceInput.value = value;
      updateClearButton(serviceInput);

      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(value).catch(function () {});
      }

      serviceInput.focus();
      fetchLogsAjax();
      return;
    }

    if (target === 'method') {
      value = value.trim().toUpperCase();
      projectFilterState[key].method = value;
    } else if (target === 'status') {
      value = value.trim();
      projectFilterState[key].status = value;
    } else {
      projectFilterState[key].search = value;
    }

    projectFilterState[key].open = true;

    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(value).catch(function () {});
    }

    renderProjects(lastFilteredLogs, true, {
      key: key,
      name: target === 'method' || target === 'status' ? target : 'search',
      start: value.length,
      end: value.length
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    const pauseBtn = document.getElementById('pauseResumeBtn');
    const refreshOnceBtn = document.getElementById('refreshOnceBtn');
    const clearBtn = document.getElementById('clearFiltersBtn');
    const projectsList = document.getElementById('projects-log-list');

    if (pauseBtn) pauseBtn.addEventListener('click', toggleAutoRefresh);
    if (refreshOnceBtn) refreshOnceBtn.addEventListener('click', fetchLogsAjax);
    if (clearBtn) clearBtn.addEventListener('click', clearFilters);

    if (projectsList) {
      projectsList.addEventListener('click', function (event) {
        const filterButton = event.target.closest('[data-filter-value]');
        if (filterButton) {
          event.preventDefault();
          applyCellFilter(filterButton);
          return;
        }

        const toggle = event.target.closest('[data-project-toggle]');
        if (!toggle) return;

        const card = toggle.closest('.ts-project-card');
        if (!card) return;

        const key = card.getAttribute('data-project-key');
        if (!key) return;

        if (!projectFilterState[key]) {
          projectFilterState[key] = { open: false, search: '', method: '', status: '' };
        }

        projectFilterState[key].open = !card.classList.contains('is-open');
        card.classList.toggle('is-open');
      });

      projectsList.addEventListener('input', function (event) {
        if (!event.target.matches('[data-project-filter]')) return;
        syncProjectStateFromDom();
        scheduleProjectRender(true);
      });

      projectsList.addEventListener('change', function (event) {
        if (!event.target.matches('[data-project-filter]')) return;
        syncProjectStateFromDom();
        scheduleProjectRender(true);
      });

      projectsList.addEventListener('keydown', function (event) {
        if (!event.target.matches('[data-project-filter="search"]')) return;
        if (event.key !== 'Enter') return;

        event.preventDefault();
        syncProjectStateFromDom();
        renderProjects(lastFilteredLogs, true, getFocusedProjectInput());
      });
    }

    enhanceClearableInputs(document);
    fetchLogsAjax();
    startAutoRefresh();
  });
</script>

</body>
</html>
