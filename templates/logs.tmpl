{{define "title"}}Requests - Loki UI{{end}}

{{define "content"}}
<section class="page-header">
  <div>
    <p class="eyebrow">Laravel request logs</p>
    <h1>Requests</h1>
    <p class="muted">
      Server-side filters query Loki directly. Filters inside each project card only filter the rows already fetched from Loki.
    </p>
  </div>
  <div class="actions">
    <button class="button secondary" type="button" id="pause-refresh">Pause auto-refresh</button>
    <button class="button" type="button" id="refresh-now">Refresh</button>
  </div>
</section>

<section class="panel filters-panel">
  <div class="panel-heading">
    <div>
      <h2>Server-side Loki filters</h2>
      <p class="muted">Use these controls to change the Loki query before rows are fetched.</p>
    </div>
  </div>

  <form id="filters-form" class="filters-grid">
    <label class="field">
      <span>Project label</span>
      <span class="clearable-input">
        <input
          type="text"
          id="filter-service"
          name="service"
          placeholder="Example: laravel-log3-loki"
          autocomplete="off"
        />
        <button class="clear-input" type="button" data-clear-target="filter-service" aria-label="Clear project label">×</button>
      </span>
    </label>

    <label class="field">
      <span>Lookback range</span>
      <select id="filter-range" name="range">
        <option value="15m">Last 15 minutes</option>
        <option value="1h" selected>Last 1 hour</option>
        <option value="6h">Last 6 hours</option>
        <option value="24h">Last 24 hours</option>
      </select>
    </label>

    <label class="field">
      <span>Max rows fetched</span>
      <input
        type="number"
        id="filter-limit"
        name="limit"
        min="1"
        max="2000"
        value="500"
        placeholder="Rows returned from Loki"
      />
    </label>

    <label class="field">
      <span>Loki text contains</span>
      <span class="clearable-input">
        <input
          type="text"
          id="filter-text"
          name="text"
          placeholder="Filter raw log text in Loki"
          autocomplete="off"
        />
        <button class="clear-input" type="button" data-clear-target="filter-text" aria-label="Clear Loki text filter">×</button>
      </span>
    </label>

    <div class="filter-actions">
      <button class="button" type="submit">Apply server filters</button>
    </div>
  </form>
</section>

<section class="panel stats-panel">
  <div class="stat">
    <span class="stat-label">Total fetched HTTP entries</span>
    <strong id="stat-total">0</strong>
  </div>
  <div class="stat">
    <span class="stat-label">2xx</span>
    <strong id="stat-2xx">0</strong>
  </div>
  <div class="stat">
    <span class="stat-label">4xx</span>
    <strong id="stat-4xx">0</strong>
  </div>
  <div class="stat">
    <span class="stat-label">5xx</span>
    <strong id="stat-5xx">0</strong>
  </div>
</section>

<section id="status-message" class="status-message" hidden></section>

<section id="projects-container" class="projects-container"></section>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 0.35rem;
    text-transform: uppercase;
  }

  .page-header h1 {
    margin: 0 0 0.35rem;
  }

  .muted {
    color: var(--muted);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .button {
    background: var(--accent);
    border: 0;
    border-radius: 0.7rem;
    color: #fff;
    cursor: pointer;
    font-weight: 700;
    padding: 0.72rem 1rem;
  }

  .button.secondary {
    background: var(--panel-border);
    color: var(--text);
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 1rem;
    box-shadow: var(--shadow);
    margin-bottom: 1rem;
    padding: 1rem;
  }

  .panel-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .panel-heading h2 {
    margin: 0 0 0.25rem;
  }

  .filters-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr)) auto;
    gap: 0.85rem;
    align-items: end;
  }

  .field {
    display: grid;
    gap: 0.35rem;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .field input,
  .field select {
    background: var(--input-bg);
    border: 1px solid var(--panel-border);
    border-radius: 0.65rem;
    color: var(--text);
    min-height: 2.65rem;
    padding: 0 0.75rem;
    width: 100%;
  }

  .clearable-input {
    display: grid;
    position: relative;
  }

  .clearable-input input {
    padding-right: 2.35rem;
  }

  .clear-input {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--muted);
    cursor: pointer;
    display: none;
    font-size: 1.25rem;
    height: 2.1rem;
    justify-content: center;
    line-height: 1;
    position: absolute;
    right: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    width: 2.1rem;
  }

  .clearable-input.has-value .clear-input {
    display: flex;
  }

  .filter-actions {
    display: flex;
    align-items: end;
  }

  .stats-panel {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .stat {
    background: var(--soft-panel);
    border: 1px solid var(--panel-border);
    border-radius: 0.85rem;
    padding: 0.85rem;
  }

  .stat-label {
    color: var(--muted);
    display: block;
    font-size: 0.78rem;
    margin-bottom: 0.25rem;
  }

  .stat strong {
    font-size: 1.5rem;
  }

  .status-message {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 0.85rem;
    color: var(--muted);
    margin-bottom: 1rem;
    padding: 0.85rem 1rem;
  }

  .projects-container {
    display: grid;
    gap: 1rem;
  }

  .project-card {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 1rem;
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .project-header {
    align-items: center;
    background: var(--soft-panel);
    border: 0;
    color: var(--text);
    cursor: pointer;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr auto;
    padding: 1rem;
    text-align: left;
    width: 100%;
  }

  .project-title {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .project-title strong {
    font-size: 1.05rem;
  }

  .project-label {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 0.18rem 0.55rem;
  }

  .project-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: flex-end;
  }

  .project-stat {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 0.25rem 0.55rem;
  }

  .project-stat strong {
    color: var(--text);
  }

  .project-toggle {
    color: var(--muted);
    font-weight: 800;
  }

  .project-body {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .project-body[hidden] {
    display: none;
  }

  .project-chart {
    background: var(--soft-panel);
    border: 1px solid var(--panel-border);
    border-radius: 0.95rem;
    padding: 0.9rem;
  }

  .project-chart-header {
    align-items: baseline;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .project-chart-title {
    font-weight: 800;
  }

  .project-chart-note {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .status-chart {
    display: grid;
    gap: 0.45rem;
  }

  .chart-row {
    align-items: center;
    display: grid;
    gap: 0.65rem;
    grid-template-columns: 4.8rem 1fr 2.8rem;
  }

  .chart-time {
    color: var(--muted);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .chart-bar {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    display: flex;
    height: 0.85rem;
    overflow: hidden;
  }

  .chart-segment {
    min-width: 0;
  }

  .chart-segment.status-2xx {
    background: #2f9e44;
  }

  .chart-segment.status-4xx {
    background: #f08c00;
  }

  .chart-segment.status-5xx {
    background: #e03131;
  }

  .chart-total {
    color: var(--muted);
    font-size: 0.72rem;
    text-align: right;
  }

  .chart-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .legend-item {
    align-items: center;
    color: var(--muted);
    display: inline-flex;
    font-size: 0.78rem;
    gap: 0.35rem;
  }

  .legend-dot {
    border-radius: 999px;
    display: inline-block;
    height: 0.65rem;
    width: 0.65rem;
  }

  .legend-dot.status-2xx {
    background: #2f9e44;
  }

  .legend-dot.status-4xx {
    background: #f08c00;
  }

  .legend-dot.status-5xx {
    background: #e03131;
  }

  .project-filters {
    display: grid;
    grid-template-columns: 1fr 10rem 10rem;
    gap: 0.75rem;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .logs-table {
    border-collapse: collapse;
    min-width: 860px;
    width: 100%;
  }

  .logs-table th,
  .logs-table td {
    border-bottom: 1px solid var(--panel-border);
    padding: 0.75rem 0.6rem;
    text-align: left;
    vertical-align: top;
  }

  .logs-table th {
    color: var(--muted);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .logs-table td {
    font-size: 0.9rem;
  }

  .click-filter {
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font: inherit;
    padding: 0;
    text-align: left;
  }

  .click-filter:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .status-pill {
    border-radius: 999px;
    display: inline-block;
    font-weight: 800;
    padding: 0.18rem 0.48rem;
  }

  .status-pill.status-2xx {
    background: rgba(47, 158, 68, 0.14);
    color: #2f9e44;
  }

  .status-pill.status-4xx {
    background: rgba(240, 140, 0, 0.14);
    color: #f08c00;
  }

  .status-pill.status-5xx {
    background: rgba(224, 49, 49, 0.14);
    color: #e03131;
  }

  .empty-state {
    color: var(--muted);
    padding: 1rem 0;
  }

  @media (max-width: 980px) {
    .page-header {
      display: grid;
    }

    .filters-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .filter-actions {
      grid-column: 1 / -1;
    }

    .stats-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-filters {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .filters-grid,
    .stats-panel {
      grid-template-columns: 1fr;
    }

    .project-header {
      grid-template-columns: 1fr;
    }

    .project-stats {
      justify-content: flex-start;
    }

    .chart-row {
      grid-template-columns: 4.2rem 1fr 2.4rem;
    }

    .logs-table {
      min-width: 0;
    }

    .logs-table thead {
      display: none;
    }

    .logs-table,
    .logs-table tbody,
    .logs-table tr,
    .logs-table td {
      display: block;
      width: 100%;
    }

    .logs-table tr {
      border: 1px solid var(--panel-border);
      border-radius: 0.85rem;
      margin-bottom: 0.75rem;
      padding: 0.65rem;
    }

    .logs-table td {
      border: 0;
      display: grid;
      gap: 0.25rem;
      padding: 0.35rem 0;
    }

    .logs-table td::before {
      color: var(--muted);
      content: attr(data-label);
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
    }
  }
</style>

<script>
  (() => {
    const form = document.getElementById("filters-form");
    const projectsContainer = document.getElementById("projects-container");
    const statusMessage = document.getElementById("status-message");
    const refreshButton = document.getElementById("refresh-now");
    const pauseButton = document.getElementById("pause-refresh");

    const statTotal = document.getElementById("stat-total");
    const stat2xx = document.getElementById("stat-2xx");
    const stat4xx = document.getElementById("stat-4xx");
    const stat5xx = document.getElementById("stat-5xx");

    const filterService = document.getElementById("filter-service");
    const filterRange = document.getElementById("filter-range");
    const filterLimit = document.getElementById("filter-limit");
    const filterText = document.getElementById("filter-text");

    let currentLogs = [];
    let autoRefreshEnabled = true;
    let autoRefreshTimer = null;
    let projectRenderTimer = null;
    let openProjects = new Set();

    const AUTO_REFRESH_MS = 15000;
    const PROJECT_RENDER_DEBOUNCE_MS = 180;

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function getNestedValue(object, path) {
      return path.split(".").reduce((value, key) => {
        if (value && Object.prototype.hasOwnProperty.call(value, key)) {
          return value[key];
        }
        return undefined;
      }, object);
    }

    function getLogValue(log, keys, fallback = "") {
      for (const key of keys) {
        const value = key.includes(".") ? getNestedValue(log, key) : log[key];
        if (value !== undefined && value !== null && value !== "") {
          return value;
        }
      }
      return fallback;
    }

    function getStatusCode(log) {
      const raw = getLogValue(log, ["status_code", "context.status_code", "http.status_code"], 0);
      const parsed = Number.parseInt(raw, 10);
      return Number.isFinite(parsed) ? parsed : 0;
    }

    function getStatusBucket(statusCode) {
      if (statusCode >= 200 && statusCode <= 299) {
        return "2xx";
      }

      if (statusCode >= 400 && statusCode <= 499) {
        return "4xx";
      }

      if (statusCode >= 500 && statusCode <= 599) {
        return "5xx";
      }

      return "other";
    }

    function getMethod(log) {
      return String(getLogValue(log, ["method", "context.method", "http.method"], "-")).toUpperCase();
    }

    function getPath(log) {
      return String(getLogValue(log, ["path", "context.path", "url.path"], "-"));
    }

    function getRequestId(log) {
      return String(getLogValue(log, ["request_id", "context.request_id"], "-"));
    }

    function getDuration(log) {
      const value = getLogValue(log, ["duration_ms", "context.duration_ms"], "");
      return value === "" ? "-" : `${value}ms`;
    }

    function getTimestamp(log) {
      return String(getLogValue(log, ["datetime", "timestamp", "time"], ""));
    }

    function getDisplayTime(log) {
      const value = getTimestamp(log);
      if (!value) {
        return "-";
      }

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return date.toLocaleString();
    }

    function getServiceLabel(log) {
      return String(getLogValue(log, ["labels.service_name", "service_name", "service"], "unknown"));
    }

    function getServiceDisplay(log) {
      return String(getLogValue(log, ["service", "context.service", "labels.service_name", "service_name"], "unknown"));
    }

    function isHttpRequestLog(log) {
      return getLogValue(log, ["message", "msg"], "") === "http_request";
    }

    function applyClientFilters(logs) {
      return logs.filter(isHttpRequestLog);
    }

    function updateClearButtons() {
      document.querySelectorAll(".clearable-input").forEach((wrapper) => {
        const input = wrapper.querySelector("input");
        if (!input) {
          return;
        }

        wrapper.classList.toggle("has-value", input.value !== "");
      });
    }

    function clearInput(input) {
      input.value = "";
      input.dispatchEvent(new Event("input", { bubbles: true }));
      input.dispatchEvent(new Event("change", { bubbles: true }));
      input.focus();
      updateClearButtons();
    }

    function setStatusMessage(message, hidden = false) {
      statusMessage.textContent = message;
      statusMessage.hidden = hidden;
    }

    function updateStats(logs) {
      const stats = logs.reduce(
        (acc, log) => {
          const bucket = getStatusBucket(getStatusCode(log));
          acc.total += 1;

          if (bucket === "2xx") {
            acc.two += 1;
          }

          if (bucket === "4xx") {
            acc.four += 1;
          }

          if (bucket === "5xx") {
            acc.five += 1;
          }

          return acc;
        },
        { total: 0, two: 0, four: 0, five: 0 },
      );

      statTotal.textContent = stats.total;
      stat2xx.textContent = stats.two;
      stat4xx.textContent = stats.four;
      stat5xx.textContent = stats.five;
    }

    function buildQueryParams() {
      const params = new URLSearchParams();

      if (filterService.value.trim()) {
        params.set("service", filterService.value.trim());
      }

      if (filterRange.value) {
        params.set("range", filterRange.value);
      }

      if (filterLimit.value) {
        params.set("limit", filterLimit.value);
      }

      if (filterText.value.trim()) {
        params.set("text", filterText.value.trim());
      }

      return params;
    }

    function groupLogsByProject(logs) {
      const groups = new Map();

      logs.forEach((log) => {
        const label = getServiceLabel(log);
        const display = getServiceDisplay(log);
        const key = label || display || "unknown";

        if (!groups.has(key)) {
          groups.set(key, {
            key,
            label,
            display,
            logs: [],
          });
        }

        groups.get(key).logs.push(log);
      });

      return Array.from(groups.values()).sort((a, b) => a.display.localeCompare(b.display));
    }

    function getProjectStats(logs) {
      return logs.reduce(
        (acc, log) => {
          const bucket = getStatusBucket(getStatusCode(log));
          acc.total += 1;

          if (bucket === "2xx") {
            acc.two += 1;
          }

          if (bucket === "4xx") {
            acc.four += 1;
          }

          if (bucket === "5xx") {
            acc.five += 1;
          }

          return acc;
        },
        { total: 0, two: 0, four: 0, five: 0 },
      );
    }

    function normalizeText(value) {
      return String(value ?? "").toLowerCase();
    }

    function filterProjectLogs(projectKey, logs) {
      const search = normalizeText(document.querySelector(`[data-project-search="${CSS.escape(projectKey)}"]`)?.value ?? "");
      const method = normalizeText(document.querySelector(`[data-project-method="${CSS.escape(projectKey)}"]`)?.value ?? "");
      const status = normalizeText(document.querySelector(`[data-project-status="${CSS.escape(projectKey)}"]`)?.value ?? "");

      return logs.filter((log) => {
        const methodValue = normalizeText(getMethod(log));
        const statusValue = String(getStatusCode(log));
        const searchable = normalizeText([
          getDisplayTime(log),
          getMethod(log),
          getPath(log),
          getStatusCode(log),
          getServiceDisplay(log),
          getServiceLabel(log),
          getRequestId(log),
          getDuration(log),
        ].join(" "));

        if (search && !searchable.includes(search)) {
          return false;
        }

        if (method && methodValue !== method) {
          return false;
        }

        if (status && !statusValue.startsWith(status)) {
          return false;
        }

        return true;
      });
    }

    function captureFocusState() {
      const activeElement = document.activeElement;

      if (!activeElement || !(activeElement instanceof HTMLInputElement)) {
        return null;
      }

      const key = activeElement.dataset.projectSearch || activeElement.dataset.projectMethod || activeElement.dataset.projectStatus;

      if (!key) {
        return null;
      }

      let type = "";

      if (activeElement.dataset.projectSearch) {
        type = "search";
      }

      if (activeElement.dataset.projectMethod) {
        type = "method";
      }

      if (activeElement.dataset.projectStatus) {
        type = "status";
      }

      return {
        key,
        type,
        value: activeElement.value,
        selectionStart: activeElement.selectionStart,
        selectionEnd: activeElement.selectionEnd,
      };
    }

    function restoreFocusState(state) {
      if (!state) {
        return;
      }

      const selector = state.type === "search"
        ? `[data-project-search="${CSS.escape(state.key)}"]`
        : state.type === "method"
          ? `[data-project-method="${CSS.escape(state.key)}"]`
          : `[data-project-status="${CSS.escape(state.key)}"]`;

      const input = document.querySelector(selector);

      if (!input) {
        return;
      }

      input.focus();

      try {
        input.setSelectionRange(state.selectionStart, state.selectionEnd);
      } catch {
        input.selectionStart = input.value.length;
        input.selectionEnd = input.value.length;
      }
    }

    function makeChartBuckets(logs) {
      const buckets = new Map();

      logs.forEach((log) => {
        const timestamp = getTimestamp(log);
        const date = new Date(timestamp);

        if (Number.isNaN(date.getTime())) {
          return;
        }

        date.setSeconds(0, 0);
        const key = date.toISOString();
        const bucket = getStatusBucket(getStatusCode(log));

        if (!buckets.has(key)) {
          buckets.set(key, {
            key,
            label: date.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }),
            total: 0,
            two: 0,
            four: 0,
            five: 0,
          });
        }

        const item = buckets.get(key);
        item.total += 1;

        if (bucket === "2xx") {
          item.two += 1;
        }

        if (bucket === "4xx") {
          item.four += 1;
        }

        if (bucket === "5xx") {
          item.five += 1;
        }
      });

      return Array.from(buckets.values()).sort((a, b) => a.key.localeCompare(b.key)).slice(-12);
    }

    function renderStatusChart(logs) {
      const buckets = makeChartBuckets(logs);

      if (buckets.length === 0) {
        return `
          <div class="project-chart">
            <div class="project-chart-header">
              <span class="project-chart-title">Status trend</span>
              <span class="project-chart-note">No timestamped rows to chart</span>
            </div>
            <div class="empty-state">No chart data available.</div>
          </div>
        `;
      }

      const maxTotal = Math.max(...buckets.map((bucket) => bucket.total), 1);

      const rows = buckets.map((bucket) => {
        const twoWidth = bucket.total ? (bucket.two / bucket.total) * 100 : 0;
        const fourWidth = bucket.total ? (bucket.four / bucket.total) * 100 : 0;
        const fiveWidth = bucket.total ? (bucket.five / bucket.total) * 100 : 0;
        const scaleWidth = (bucket.total / maxTotal) * 100;

        return `
          <div class="chart-row" title="2xx: ${bucket.two}, 4xx: ${bucket.four}, 5xx: ${bucket.five}">
            <span class="chart-time">${escapeHtml(bucket.label)}</span>
            <div class="chart-bar" style="width: ${scaleWidth}%">
              <span class="chart-segment status-2xx" style="width: ${twoWidth}%"></span>
              <span class="chart-segment status-4xx" style="width: ${fourWidth}%"></span>
              <span class="chart-segment status-5xx" style="width: ${fiveWidth}%"></span>
            </div>
            <span class="chart-total">${bucket.total}</span>
          </div>
        `;
      }).join("");

      return `
        <div class="project-chart">
          <div class="project-chart-header">
            <span class="project-chart-title">Status trend</span>
            <span class="project-chart-note">Last ${buckets.length} minute bucket${buckets.length === 1 ? "" : "s"}</span>
          </div>
          <div class="status-chart">${rows}</div>
          <div class="chart-legend">
            <span class="legend-item"><span class="legend-dot status-2xx"></span>2xx</span>
            <span class="legend-item"><span class="legend-dot status-4xx"></span>4xx</span>
            <span class="legend-item"><span class="legend-dot status-5xx"></span>5xx</span>
          </div>
        </div>
      `;
    }

    function renderProjectTable(project, logs) {
      if (logs.length === 0) {
        return `<div class="empty-state">No rows match this project's local filters.</div>`;
      }

      const rows = logs.map((log) => {
        const statusCode = getStatusCode(log);
        const statusBucket = getStatusBucket(statusCode);
        const method = getMethod(log);
        const path = getPath(log);
        const displayTime = getDisplayTime(log);
        const serviceDisplay = getServiceDisplay(log);
        const serviceLabel = getServiceLabel(log);
        const requestId = getRequestId(log);
        const duration = getDuration(log);

        return `
          <tr>
            <td data-label="Time">
              <button class="click-filter" type="button" data-fill-project-search="${escapeHtml(project.key)}" data-fill-value="${escapeHtml(displayTime)}">
                ${escapeHtml(displayTime)}
              </button>
            </td>
            <td data-label="Verb">
              <button class="click-filter" type="button" data-fill-project-method="${escapeHtml(project.key)}" data-fill-value="${escapeHtml(method)}">
                ${escapeHtml(method)}
              </button>
            </td>
            <td data-label="Path">
              <button class="click-filter" type="button" data-fill-project-search="${escapeHtml(project.key)}" data-fill-value="${escapeHtml(path)}">
                ${escapeHtml(path)}
              </button>
            </td>
            <td data-label="Status">
              <button class="click-filter status-pill status-${escapeHtml(statusBucket)}" type="button" data-fill-project-status="${escapeHtml(project.key)}" data-fill-value="${escapeHtml(String(statusCode))}">
                ${escapeHtml(statusCode || "-")}
              </button>
            </td>
            <td data-label="Duration">${escapeHtml(duration)}</td>
            <td data-label="Service">
              <button class="click-filter" type="button" data-fill-server-service="${escapeHtml(serviceLabel)}">
                ${escapeHtml(serviceDisplay)}
              </button>
            </td>
            <td data-label="Request">${escapeHtml(requestId)}</td>
          </tr>
        `;
      }).join("");

      return `
        <div class="table-wrap">
          <table class="logs-table">
            <thead>
              <tr>
                <th>Time</th>
                <th>Verb</th>
                <th>Path</th>
                <th>Status</th>
                <th>Duration</th>
                <th>Service</th>
                <th>Request</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      `;
    }

    function renderProjects() {
      const focusState = captureFocusState();
      const filteredLogs = applyClientFilters(currentLogs);
      const projects = groupLogsByProject(filteredLogs);

      updateStats(filteredLogs);

      if (projects.length === 0) {
        projectsContainer.innerHTML = `<section class="panel empty-state">No HTTP request logs found for the selected server-side filters.</section>`;
        setStatusMessage("", true);
        return;
      }

      if (openProjects.size === 0) {
        openProjects.add(projects[0].key);
      }

      projectsContainer.innerHTML = projects.map((project) => {
        const isOpen = openProjects.has(project.key);
        const projectStats = getProjectStats(project.logs);
        const visibleLogs = filterProjectLogs(project.key, project.logs);

        return `
          <section class="project-card" data-project="${escapeHtml(project.key)}">
            <button class="project-header" type="button" data-toggle-project="${escapeHtml(project.key)}" aria-expanded="${isOpen ? "true" : "false"}">
              <span>
                <span class="project-title">
                  <strong>${escapeHtml(project.display)}</strong>
                  <span class="project-label">${escapeHtml(project.label)}</span>
                </span>
              </span>
              <span class="project-stats">
                <span class="project-stat">Total <strong>${projectStats.total}</strong></span>
                <span class="project-stat">2xx <strong>${projectStats.two}</strong></span>
                <span class="project-stat">4xx <strong>${projectStats.four}</strong></span>
                <span class="project-stat">5xx <strong>${projectStats.five}</strong></span>
                <span class="project-toggle">${isOpen ? "−" : "+"}</span>
              </span>
            </button>

            <div class="project-body" ${isOpen ? "" : "hidden"}>
              ${renderStatusChart(visibleLogs)}

              <div class="project-filters">
                <label class="field">
                  <span>Search this project</span>
                  <span class="clearable-input">
                    <input type="text" data-project-search="${escapeHtml(project.key)}" placeholder="Path, time, request id..." autocomplete="off" />
                    <button class="clear-input" type="button" data-clear-project-search="${escapeHtml(project.key)}" aria-label="Clear project search">×</button>
                  </span>
                </label>

                <label class="field">
                  <span>Method</span>
                  <span class="clearable-input">
                    <input type="text" data-project-method="${escapeHtml(project.key)}" placeholder="GET" autocomplete="off" />
                    <button class="clear-input" type="button" data-clear-project-method="${escapeHtml(project.key)}" aria-label="Clear project method">×</button>
                  </span>
                </label>

                <label class="field">
                  <span>Status</span>
                  <span class="clearable-input">
                    <input type="text" data-project-status="${escapeHtml(project.key)}" placeholder="404 or 5" autocomplete="off" />
                    <button class="clear-input" type="button" data-clear-project-status="${escapeHtml(project.key)}" aria-label="Clear project status">×</button>
                  </span>
                </label>
              </div>

              ${renderProjectTable(project, visibleLogs)}
            </div>
          </section>
        `;
      }).join("");

      restoreFocusState(focusState);
      updateClearButtons();
      setStatusMessage("", true);
    }

    function scheduleProjectRender() {
      window.clearTimeout(projectRenderTimer);
      projectRenderTimer = window.setTimeout(renderProjects, PROJECT_RENDER_DEBOUNCE_MS);
    }

    async function fetchLogs() {
      const params = buildQueryParams();

      setStatusMessage("Loading request logs...");

      const response = await fetch(`/api/logs?${params.toString()}`, {
        headers: { "Accept": "application/json" },
      });

      if (!response.ok) {
        throw new Error(`Request failed with status ${response.status}`);
      }

      const payload = await response.json();
      currentLogs = Array.isArray(payload.logs) ? payload.logs : [];
      renderProjects();
      setStatusMessage("", true);
    }

    function resetAutoRefresh() {
      window.clearInterval(autoRefreshTimer);

      if (!autoRefreshEnabled) {
        return;
      }

      autoRefreshTimer = window.setInterval(() => {
        fetchLogs().catch((error) => {
          setStatusMessage(error.message);
        });
      }, AUTO_REFRESH_MS);
    }

    function applyServerServiceFilter(value) {
      filterService.value = value;
      updateClearButtons();
      fetchLogs()
        .then(resetAutoRefresh)
        .catch((error) => setStatusMessage(error.message));
    }

    document.addEventListener("click", (event) => {
      const clearButton = event.target.closest("[data-clear-target]");
      if (clearButton) {
        const input = document.getElementById(clearButton.dataset.clearTarget);
        if (input) {
          clearInput(input);
        }

        return;
      }

      const clearProjectSearch = event.target.closest("[data-clear-project-search]");
      if (clearProjectSearch) {
        const input = document.querySelector(`[data-project-search="${CSS.escape(clearProjectSearch.dataset.clearProjectSearch)}"]`);
        if (input) {
          clearInput(input);
        }

        return;
      }

      const clearProjectMethod = event.target.closest("[data-clear-project-method]");
      if (clearProjectMethod) {
        const input = document.querySelector(`[data-project-method="${CSS.escape(clearProjectMethod.dataset.clearProjectMethod)}"]`);
        if (input) {
          clearInput(input);
        }

        return;
      }

      const clearProjectStatus = event.target.closest("[data-clear-project-status]");
      if (clearProjectStatus) {
        const input = document.querySelector(`[data-project-status="${CSS.escape(clearProjectStatus.dataset.clearProjectStatus)}"]`);
        if (input) {
          clearInput(input);
        }

        return;
      }

      const toggleButton = event.target.closest("[data-toggle-project]");
      if (toggleButton) {
        const key = toggleButton.dataset.toggleProject;

        if (openProjects.has(key)) {
          openProjects.delete(key);
        } else {
          openProjects.add(key);
        }

        renderProjects();
        return;
      }

      const fillServerService = event.target.closest("[data-fill-server-service]");
      if (fillServerService) {
        applyServerServiceFilter(fillServerService.dataset.fillServerService);
        return;
      }

      const fillProjectSearch = event.target.closest("[data-fill-project-search]");
      if (fillProjectSearch) {
        const input = document.querySelector(`[data-project-search="${CSS.escape(fillProjectSearch.dataset.fillProjectSearch)}"]`);
        if (input) {
          input.value = fillProjectSearch.dataset.fillValue;
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
        }

        return;
      }

      const fillProjectMethod = event.target.closest("[data-fill-project-method]");
      if (fillProjectMethod) {
        const input = document.querySelector(`[data-project-method="${CSS.escape(fillProjectMethod.dataset.fillProjectMethod)}"]`);
        if (input) {
          input.value = fillProjectMethod.dataset.fillValue;
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
        }

        return;
      }

      const fillProjectStatus = event.target.closest("[data-fill-project-status]");
      if (fillProjectStatus) {
        const input = document.querySelector(`[data-project-status="${CSS.escape(fillProjectStatus.dataset.fillProjectStatus)}"]`);
        if (input) {
          input.value = fillProjectStatus.dataset.fillValue;
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
        }
      }
    });

    document.addEventListener("input", (event) => {
      if (event.target.matches("input")) {
        updateClearButtons();
      }

      if (
        event.target.matches("[data-project-search]") ||
        event.target.matches("[data-project-method]") ||
        event.target.matches("[data-project-status]")
      ) {
        scheduleProjectRender();
      }
    });

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      fetchLogs()
        .then(resetAutoRefresh)
        .catch((error) => setStatusMessage(error.message));
    });

    refreshButton.addEventListener("click", () => {
      fetchLogs()
        .then(resetAutoRefresh)
        .catch((error) => setStatusMessage(error.message));
    });

    pauseButton.addEventListener("click", () => {
      autoRefreshEnabled = !autoRefreshEnabled;
      pauseButton.textContent = autoRefreshEnabled ? "Pause auto-refresh" : "Resume auto-refresh";
      resetAutoRefresh();
    });

    updateClearButtons();

    fetchLogs()
      .then(resetAutoRefresh)
      .catch((error) => setStatusMessage(error.message));
  })();
</script>
{{end}}