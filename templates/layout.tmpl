{{ define "layout" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Loki UI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body { font-family: sans-serif; font-size: 14px; margin: 16px; }
    h1 { font-size: 18px; margin-bottom: 12px; }
    form { margin-bottom: 12px; }
    label { margin-right: 8px; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 4px 8px; vertical-align: top; }
    th { background: #f3f3f3; }
    .level-INFO { color: #2c7; }
    .level-ERROR { color: #c22; font-weight: bold; }
    .log-details { display: none; white-space: pre; font-family: monospace; background: #111; color: #ddd; padding: 8px; margin-top: 4px; }
    button.toggle { font-size: 12px; padding: 2px 6px; }
  </style>
  <script>
    function toggleDetails(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.style.display = (el.style.display === 'none' || el.style.display === '') ? 'block' : 'none';
    }
  </script>
</head>
<body>
  {{ template "content" . }}
</body>
</html>
{{ end }}
