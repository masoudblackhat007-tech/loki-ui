{{ define "docs" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Loki UI - Docs</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    :root {
      --bg: #020617;
      --panel: #0f172a;
      --border: #1f2937;
      --text: #e5e7eb;
      --muted: #9ca3af;
      --primary: #22c55e;
      --primary-soft: rgba(34, 197, 94, 0.14);
      --code-bg: #020617;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 20% -10%, rgba(34, 197, 94, 0.08), transparent 45%),
        radial-gradient(circle at 80% -10%, rgba(59, 130, 246, 0.06), transparent 45%),
        var(--bg);
      color: var(--text);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .shell {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 28px 16px;
    }

    .topbar {
      width: min(980px, 100%);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 18px;
    }

    .brand {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .brand-title {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .brand-subtitle {
      font-size: 12px;
      color: var(--muted);
    }

    .nav-link {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 8px 12px;
      color: var(--muted);
      background: rgba(15, 23, 42, 0.72);
      font-size: 13px;
    }

    .doc-card {
      width: min(980px, 100%);
      background: rgba(15, 23, 42, 0.86);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
      overflow: hidden;
    }

    .doc-header {
      padding: 26px 28px 18px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(17, 24, 39, 0.95), rgba(15, 23, 42, 0.82));
    }

    .doc-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
      color: var(--muted);
      font-size: 12px;
    }

    .pill {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 5px 9px;
      background: rgba(2, 6, 23, 0.5);
    }

    .doc-title {
      margin: 0;
      font-size: clamp(24px, 4vw, 34px);
      line-height: 1.18;
      letter-spacing: -0.03em;
    }

    .doc-body {
      padding: 28px;
      line-height: 1.78;
      font-size: 15px;
      color: #d1d5db;
    }

    .doc-body h1,
    .doc-body h2,
    .doc-body h3 {
      color: var(--text);
      line-height: 1.3;
      letter-spacing: -0.02em;
    }

    .doc-body h1 {
      font-size: 28px;
      margin: 0 0 18px;
    }

    .doc-body h2 {
      font-size: 22px;
      margin: 34px 0 12px;
      padding-top: 16px;
      border-top: 1px solid rgba(31, 41, 55, 0.8);
    }

    .doc-body h3 {
      font-size: 17px;
      margin: 24px 0 10px;
    }

    .doc-body p {
      margin: 0 0 14px;
    }

    .doc-body ul {
      margin: 0 0 16px;
      padding-left: 22px;
    }

    .doc-body li {
      margin: 6px 0;
    }

    .doc-body code {
      background: rgba(2, 6, 23, 0.76);
      border: 1px solid rgba(31, 41, 55, 0.85);
      border-radius: 7px;
      padding: 2px 6px;
      color: #f8fafc;
      font-size: 0.92em;
    }

    .doc-body pre {
      margin: 16px 0;
      padding: 16px;
      overflow-x: auto;
      background: var(--code-bg);
      border: 1px solid rgba(31, 41, 55, 0.9);
      border-radius: 16px;
    }

    .doc-body pre code {
      border: 0;
      padding: 0;
      background: transparent;
      white-space: pre;
      color: #e5e7eb;
    }

    .pager {
      width: min(980px, 100%);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-top: 18px;
    }

    .pager-btn {
      min-width: 132px;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 12px 16px;
      background: var(--primary-soft);
      color: var(--text);
      font-weight: 700;
    }

    .pager-btn.disabled {
      opacity: 0.38;
      pointer-events: none;
      background: rgba(15, 23, 42, 0.74);
      color: var(--muted);
    }

    .pager-status {
      color: var(--muted);
      font-size: 13px;
      text-align: center;
    }

    @media (max-width: 720px) {
      .shell {
        padding: 18px 10px;
      }

      .topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .doc-header,
      .doc-body {
        padding: 20px;
      }

      .pager {
        display: grid;
        grid-template-columns: 1fr;
      }

      .pager-status {
        order: -1;
      }

      .pager-btn {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <main class="shell">
    <header class="topbar">
      <div class="brand">
        <div class="brand-title">Loki UI Docs</div>
        <div class="brand-subtitle">Internal documentation viewer</div>
      </div>

      <a class="nav-link" href="/logs">← Back to Requests</a>
    </header>

    <article class="doc-card">
      <header class="doc-header">
        <div class="doc-meta">
          <span class="pill">Page {{ .Page }} of {{ .Total }}</span>
          <span class="pill">{{ .CurrentFile }}</span>
        </div>

        <h1 class="doc-title">{{ .Title }}</h1>
      </header>

      <section class="doc-body">
        {{ .BodyHTML }}
      </section>
    </article>

    <nav class="pager" aria-label="Documentation pagination">
      {{ if .HasPrev }}
        <a class="pager-btn" href="/docs?page={{ .PrevPage }}">← Back</a>
      {{ else }}
        <span class="pager-btn disabled">← Back</span>
      {{ end }}

      <div class="pager-status">Reading page {{ .Page }} of {{ .Total }}</div>

      {{ if .HasNext }}
        <a class="pager-btn" href="/docs?page={{ .NextPage }}">Next →</a>
      {{ else }}
        <span class="pager-btn disabled">Next →</span>
      {{ end }}
    </nav>
  </main>
</body>
</html>
{{ end }}